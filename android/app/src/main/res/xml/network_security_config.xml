<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Radio stream domains -->
        <domain includeSubdomains="true">bbcmedia.co.uk</domain>
        <domain includeSubdomains="true">streamguys1.com</domain>
        <domain includeSubdomains="true">akacast.akamaistream.net</domain>
        <domain includeSubdomains="true">getaj.net</domain>
        <domain includeSubdomains="true">akamaized.net</domain>
        <!-- Image domains -->
        <domain includeSubdomains="true">pixabay.com</domain>
        <domain includeSubdomains="true">upload.wikimedia.org</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>